# ── LLM Provider ─────────────────────────────────────────────────────────────
# "groq"   → FREE, fastest  — get key at console.groq.com
# "gemini" → FREE, 1500/day — get key at aistudio.google.com/apikey
# "openai" → paid           — get key at platform.openai.com

LLM_PROVIDER=groq

# Groq (free, ~2000 req/day, resets per minute for rate limits)
GROQ_API_KEY=gsk_your-groq-key-here

# Gemini (free, 1500 req/day, resets daily)
GEMINI_API_KEY=

# OpenAI (paid)
OPENAI_API_KEY=

# GitHub (only for private repos)
GITHUB_TOKEN=

CHROMA_PATH=./chroma_db
ALLOWED_ORIGINS=http://localhost:3001
# config: add root .env and update example
# config: add root .env and update example
# config: add root .env and update example
